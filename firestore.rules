
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Public Read-Only
    match /quran_surahs/{surahId} {
      allow read: if true;
      allow write: if false;
    }
    match /quran_ayahs/{docId} {
      allow read: if true;
      allow write: if false;
    }
    match /duas/{duaId} {
      allow read: if true;
      allow write: if false;
    }

    // User Private
    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/bookmarks/{bookmarkId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/favorite_duas/{duaId} {
      allow read, write: if isOwner(uid);
    }
    match /users/{uid}/learn_progress/progress {
      allow read, write: if isOwner(uid);
    }
  }
}
