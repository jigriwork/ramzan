
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Public Collections: Allow anyone to read, authenticated users to seed/write
    match /quran_surahs/{surahId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /quran_ayahs/{ayahId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /duas/{duaId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // User Private Data
    match /users/{uid} {
      allow read, write: if isOwner(uid);
      
      // Nested subcollections for better organizational matching
      match /bookmarks/{bookmarkId} {
        allow read, write: if isOwner(uid);
      }
      
      match /favorite_duas/{duaId} {
        allow read, write: if isOwner(uid);
      }
      
      match /learn_progress/{document=**} {
        allow read, write: if isOwner(uid);
      }
    }
  }
}
