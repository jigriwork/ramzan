
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Public Collections: Allow anyone to read (get and list)
    // We use a more explicit match for collections to avoid 'list' permission issues in some clients
    match /quran_surahs/{surahId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /quran_surahs {
      allow read: if true;
    }
    
    match /quran_ayahs/{ayahId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /quran_ayahs {
      allow read: if true;
    }
    
    match /duas/{duaId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /duas {
      allow read: if true;
    }

    // User Private Data
    match /users/{uid} {
      allow read, write: if isOwner(uid);
      
      match /bookmarks/{document=**} {
        allow read, write: if isOwner(uid);
      }
      
      match /favorite_duas/{document=**} {
        allow read, write: if isOwner(uid);
      }
      
      match /learn_progress/{document=**} {
        allow read, write: if isOwner(uid);
      }
    }
  }
}
