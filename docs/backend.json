
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "city": { "type": "string" },
        "mode": { "type": "string", "enum": ["adult", "kids"] },
        "theme": { "type": "string", "enum": ["light", "dark", "system"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastRead": {
          "type": "object",
          "properties": {
            "surahId": { "type": "string" },
            "ayahNo": { "type": "number" },
            "updatedAt": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["id", "mode", "theme", "createdAt"]
    },
    "QuranSurah": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "QuranSurah",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "index": { "type": "number" },
        "nameArabic": { "type": "string" },
        "nameEnglish": { "type": "string" },
        "nameUrdu": { "type": "string" },
        "nameHindi": { "type": "string" },
        "ayahCount": { "type": "number" }
      },
      "required": ["id", "index", "nameArabic", "nameEnglish"]
    },
    "QuranAyah": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "QuranAyah",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "surahId": { "type": "string" },
        "ayahNo": { "type": "number" },
        "arabic": { "type": "string" },
        "transliteration": { "type": "string" },
        "translation_en": { "type": "string" },
        "translation_ur": { "type": "string" },
        "translation_hi": { "type": "string" }
      },
      "required": ["id", "surahId", "ayahNo", "arabic"]
    },
    "Dua": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Dua",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "category": { "type": "string" },
        "arabic": { "type": "string" },
        "transliteration": { "type": "string" },
        "translation_en": { "type": "string" },
        "translation_ur": { "type": "string" },
        "translation_hi": { "type": "string" }
      },
      "required": ["id", "title", "category", "arabic"]
    },
    "Bookmark": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Bookmark",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "surahId": { "type": "string" },
        "ayahNo": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "surahId", "ayahNo", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/quran_surahs/{surahId}",
        "definition": {
          "entityName": "QuranSurah",
          "description": "Public Quran Surah list."
        }
      },
      {
        "path": "/quran_ayahs/{docId}",
        "definition": {
          "entityName": "QuranAyah",
          "description": "Public Quran Ayah text."
        }
      },
      {
        "path": "/duas/{duaId}",
        "definition": {
          "entityName": "Dua",
          "description": "Public Duas."
        }
      },
      {
        "path": "/users/{uid}",
        "definition": {
          "entityName": "UserProfile",
          "description": "Private User Profile."
        }
      },
      {
        "path": "/users/{uid}/bookmarks/{bookmarkId}",
        "definition": {
          "entityName": "Bookmark",
          "description": "User's bookmarked Ayahs."
        }
      },
      {
        "path": "/users/{uid}/favorite_duas/{duaId}",
        "definition": {
          "entityName": "Dua",
          "description": "User's favorited Duas."
        }
      },
      {
        "path": "/users/{uid}/learn_progress/progress",
        "definition": {
          "entityName": "LearnProgress",
          "description": "User's learning progress."
        }
      }
    ]
  }
}
